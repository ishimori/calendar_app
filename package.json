{
  "name": "calendar-app",
  "version": "0.1.0",
  "description": "Excelカレンダー(業務予定表+ガント) のWebアプリ化",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:fe": "vite --config vite.config.ts",
    "dev:all": "bash scripts/dev-start.sh",
    "dev:kill": "bash scripts/dev-kill.sh",
    "build": "tsc --noEmit",
    "build:fe": "vite build --config vite.config.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.59.20",
    "hono": "^4.6.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
